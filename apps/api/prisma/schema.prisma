// ─── Security & Compliance ────────────────────────────────────────────────────

// ─── E-Signature ─────────────────────────────────────────────────────────────

model EsignDocument {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  createdById    String
  createdBy      User             @relation("CreatedDocuments", fields: [createdById], references: [id])
  title          String
  type           String
  content        String           @db.Text
  status         String           @default("DRAFT")
  documentHash   String?
  dueDate        DateTime?
  completedAt    DateTime?
  signatories    EsignSignatory[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([tenantId, status])
}

model EsignSignatory {
  id             String        @id @default(cuid())
  documentId     String
  document       EsignDocument @relation(fields: [documentId], references: [id])
  userId         String
  user           User          @relation("UserSignatories", fields: [userId], references: [id])
  order          Int           @default(0)
  status         String        @default("PENDING")
  signedAt       DateTime?
  signatureData  String?       @db.Text
  signatureHash  String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
}

model EsignTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  type        String
  content     String   @db.Text
  variables   Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Custom Workflows ─────────────────────────────────────────────────────────

model CustomWorkflow {
  id            String             @id @default(cuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  createdById   String
  createdBy     User               @relation("CreatedWorkflows", fields: [createdById], references: [id])
  name          String
  description   String?
  trigger       String
  status        String             @default("DRAFT")
  steps         WorkflowStep[]
  instances     WorkflowInstance[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([tenantId])
}

model WorkflowStep {
  id           String         @id @default(cuid())
  workflowId   String
  workflow     CustomWorkflow @relation(fields: [workflowId], references: [id])
  type         String
  name         String
  order        Int
  config       Json           @default("{}")
  trueStepId   String?
  falseStepId  String?
  nextStepId   String?
  createdAt    DateTime       @default(now())
}

model WorkflowInstance {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  workflowId      String
  workflow        CustomWorkflow @relation(fields: [workflowId], references: [id])
  triggeredById   String
  triggeredBy     User           @relation("TriggeredInstances", fields: [triggeredById], references: [id])
  currentStepId   String?
  status          String         @default("RUNNING")
  data            Json           @default("{}")
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// =============================================================================
// SMART SCHOOL — Hikvision Face Recognition Attendance
// =============================================================================

model School {
  id            String          @id @default(cuid())
  name          String
  address       String?
  phone         String?
  email         String?
  logo          String?
  tenantId      String?
  settings      Json            @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  classes       SchoolClass[]
  students      SchoolStudent[]
  cameras       SchoolCamera[]
  attendances   SchoolAttendance[]
  notifLogs     SchoolNotifLog[]
  journals      SchoolJournal[]

  @@map("schools")
}

model SchoolClass {
  id          String           @id @default(cuid())
  schoolId    String
  school      School           @relation(fields: [schoolId], references: [id])
  name        String
  grade       Int
  teacherName String?
  students    SchoolStudent[]
  attendances SchoolAttendance[]
  journals    SchoolJournal[]
  createdAt   DateTime         @default(now())

  @@map("school_classes")
}

// ─── School Journal ───────────────────────────────────────────────────────────

model SchoolJournal {
  id        String         @id @default(cuid())
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id])
  classId   String
  class     SchoolClass    @relation(fields: [classId], references: [id])
  subject   String
  period    String
  grades    JournalGrade[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([schoolId, classId, subject, period])
  @@map("school_journals")
}

model JournalGrade {
  id        String        @id @default(cuid())
  journalId String
  journal   SchoolJournal @relation(fields: [journalId], references: [id])
  studentId String
  student   SchoolStudent @relation(fields: [studentId], references: [id])
  date      DateTime
  grade     Int?
  isAbsent  Boolean       @default(false)
  note      String?
  createdAt DateTime      @default(now())

  @@unique([journalId, studentId, date])
  @@map("journal_grades")
}

// =============================================================================
// KINDERGARTEN CLOUD
// =============================================================================

model Kindergarten {
  id          String             @id @default(cuid())
  name        String
  address     String?
  phone       String?
  logo        String?
  tenantId    String?
  settings    Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  groups      KinderGroup[]
  children    KinderChild[]
  cameras     KinderCamera[]
  attendance  KinderAttendance[]
  pickupLogs  PickupLog[]
  menus       KinderMenu[]

  @@map("kindergartens")
}

model KinderGroup {
  id             String             @id @default(cuid())
  kindergartenId String
  kindergarten   Kindergarten       @relation(fields: [kindergartenId], references: [id])
  name           String
  ageMin         Int
  ageMax         Int
  capacity       Int                @default(20)
  room           String?
  teacherName    String?
  children       KinderChild[]
  attendance     KinderAttendance[]
  createdAt      DateTime           @default(now())

  @@map("kinder_groups")
}

model KinderChild {
  id             String             @id @default(cuid())
  kindergartenId String
  kindergarten   Kindergarten       @relation(fields: [kindergartenId], references: [id])
  groupId        String
  group          KinderGroup        @relation(fields: [groupId], references: [id])
  childCode      String
  firstName      String
  lastName       String
  birthDate      DateTime?
  gender         String             @default("MALE")
  photo          String?
  faceEmbedding  String?            @db.Text
  allergies      String[]
  status         String             @default("ACTIVE")
  parents        KinderParent[]
  pickupPersons  PickupPerson[]
  attendance     KinderAttendance[]
  pickupLogs     PickupLog[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([kindergartenId, childCode])
  @@map("kinder_children")
}

model KinderParent {
  id             String      @id @default(cuid())
  childId        String
  child          KinderChild @relation(fields: [childId], references: [id])
  name           String
  phone          String
  telegramChatId String?
  relation       String      @default("PARENT")
  isPrimary      Boolean     @default(false)
  receiveAlerts  Boolean     @default(true)
  createdAt      DateTime    @default(now())

  @@map("kinder_parents")
}

model PickupPerson {
  id             String      @id @default(cuid())
  childId        String
  child          KinderChild @relation(fields: [childId], references: [id])
  name           String
  relation       String
  phone          String
  telegramChatId String?
  faceRegistered Boolean     @default(false)
  faceEmbedding  String?     @db.Text
  authorized     Boolean     @default(true)
  pickupLogs     PickupLog[]
  addedAt        DateTime    @default(now())

  @@map("pickup_persons")
}

model KinderCamera {
  id             String       @id @default(cuid())
  kindergartenId String
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id])
  name           String
  ip             String
  port           Int          @default(80)
  username       String
  password       String
  location       String       @default("ENTRANCE")
  isOnline       Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("kinder_cameras")
}

model KinderAttendance {
  id             String       @id @default(cuid())
  kindergartenId String
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id])
  childId        String
  child          KinderChild  @relation(fields: [childId], references: [id])
  groupId        String
  group          KinderGroup  @relation(fields: [groupId], references: [id])
  date           DateTime
  arrivalTime    DateTime?
  arrivalPhoto   String?
  departureTime  DateTime?
  departurePhoto String?
  pickedUpBy     String?
  status         String       @default("ABSENT")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([childId, date])
  @@index([kindergartenId, date])
  @@map("kinder_attendance")
}

model PickupLog {
  id             String        @id @default(cuid())
  kindergartenId String
  kindergarten   Kindergarten  @relation(fields: [kindergartenId], references: [id])
  childId        String
  child          KinderChild   @relation(fields: [childId], references: [id])
  pickupPersonId String?
  pickupPerson   PickupPerson? @relation(fields: [pickupPersonId], references: [id])
  timestamp      DateTime      @default(now())
  faceConfidence Float?
  isAuthorized   Boolean       @default(false)
  photo          String?
  alertSent      Boolean       @default(false)
  note           String?

  @@index([kindergartenId, timestamp])
  @@map("pickup_logs")
}

model KinderMenu {
  id             String       @id @default(cuid())
  kindergartenId String
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id])
  date           DateTime
  breakfast      String?
  lunch          String?
  snack          String?
  dinner         String?
  createdAt      DateTime     @default(now())

  @@unique([kindergartenId, date])
  @@map("kinder_menus")
}

// =============================================================================
// BILLING
// =============================================================================

model BillingAccount {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  plan               String    @default("STARTER")
  clouds             String[]
  status             String    @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAt           DateTime?
  paymentMethod      String?
  paymentLast4       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invoices           Invoice[]

  @@map("billing_accounts")
}

model Invoice {
  id               String         @id @default(cuid())
  billingAccountId String
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])
  period           String
  amount           Decimal        @db.Decimal(15, 2)
  currency         String         @default("UZS")
  status           String         @default("PENDING")
  dueDate          DateTime
  paidAt           DateTime?
  pdfUrl           String?
  items            Json           @default("[]")
  createdAt        DateTime       @default(now())

  @@index([billingAccountId])
  @@map("invoices")
}

model SchoolStudent {
  id            String            @id @default(cuid())
  schoolId      String
  school        School            @relation(fields: [schoolId], references: [id])
  classId       String
  class         SchoolClass       @relation(fields: [classId], references: [id])
  studentCode   String
  firstName     String
  lastName      String
  birthDate     DateTime?
  gender        String            @default("MALE")
  photo         String?
  faceEmbedding String?           @db.Text
  status        String            @default("ACTIVE")
  parents       SchoolParent[]
  attendances   SchoolAttendance[]
  grades        JournalGrade[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([schoolId, studentCode])
  @@map("school_students")
}

model SchoolParent {
  id            String         @id @default(cuid())
  studentId     String
  student       SchoolStudent  @relation(fields: [studentId], references: [id])
  name          String
  phone         String
  telegramChatId String?
  relation      String         @default("PARENT")
  receivesTelegram Boolean     @default(true)
  receivesSms   Boolean        @default(true)
  createdAt     DateTime       @default(now())

  @@map("school_parents")
}

model SchoolCamera {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  ip        String
  port      Int      @default(80)
  rtspPort  Int      @default(554)
  username  String
  password  String
  rtspPath  String   @default("Streaming/channels/101")
  location  String   @default("ENTRANCE")
  isOnline  Boolean  @default(false)
  lastSeen  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances SchoolAttendance[]

  @@map("school_cameras")
}

model SchoolAttendance {
  id              String         @id @default(cuid())
  schoolId        String
  school          School         @relation(fields: [schoolId], references: [id])
  studentId       String
  student         SchoolStudent  @relation(fields: [studentId], references: [id])
  classId         String
  class           SchoolClass    @relation(fields: [classId], references: [id])
  cameraId        String?
  camera          SchoolCamera?  @relation(fields: [cameraId], references: [id])
  date            DateTime
  arrivalTime     DateTime?
  arrivalPhoto    String?
  departureTime   DateTime?
  departurePhoto  String?
  status          String         @default("ABSENT")
  faceConfidence  Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@map("school_attendance")
}

model SchoolNotifLog {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  studentId   String
  parentName  String
  channel     String
  eventType   String
  message     String   @db.Text
  status      String   @default("SENT")
  sentAt      DateTime @default(now())

  @@index([schoolId, sentAt])
  @@map("school_notif_logs")
}

// =============================================================================
// ERP — BUXGALTERIYA
// =============================================================================

model ChartOfAccount {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  type        String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentCode  String?
  currency    String   @default("UZS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  debitLines  JournalLine[] @relation("DebitAccount")
  creditLines JournalLine[] @relation("CreditAccount")

  @@unique([tenantId, code])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id          String        @id @default(cuid())
  tenantId    String
  docNumber   String
  description String
  date        DateTime
  status      String        @default("DRAFT") // DRAFT, POSTED, REVERSED
  createdById String?
  createdAt   DateTime      @default(now())
  lines       JournalLine[]

  @@index([tenantId, date])
  @@map("journal_entries")
}

model JournalLine {
  id          String        @id @default(cuid())
  entryId     String
  entry       JournalEntry  @relation(fields: [entryId], references: [id])
  debitCode   String?
  debitAcct   ChartOfAccount? @relation("DebitAccount", fields: [debitCode], references: [id])
  creditCode  String?
  creditAcct  ChartOfAccount? @relation("CreditAccount", fields: [creditCode], references: [id])
  amount      Decimal       @db.Decimal(15, 2)
  description String?
  createdAt   DateTime      @default(now())

  @@map("journal_lines")
}

// =============================================================================
// ERP — OMBORXONA
// =============================================================================

model Product {
  id          String           @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  category    String?
  description String?
  unit        String           @default("dona")
  price       Decimal          @db.Decimal(15, 2)
  minQty      Int              @default(0)
  location    String?
  supplierId  String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  stockItems  StockItem[]
  movements   StockMovement[]

  @@unique([tenantId, sku])
  @@map("products")
}

model StockItem {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  warehouseId String?
  qty         Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@map("stock_items")
}

model StockMovement {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        String   // IN, OUT, TRANSFER
  qty         Int
  fromLocation String?
  toLocation  String?
  docNumber   String?
  reason      String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// =============================================================================
// ERP — SAVDO (CRM)
// =============================================================================

model Client {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String   @default("COMPANY") // COMPANY, INDIVIDUAL
  contactName String?
  phone       String?
  email       String?
  address     String?
  status      String   @default("ACTIVE") // ACTIVE, VIP, INACTIVE
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals       Deal[]

  @@index([tenantId])
  @@map("clients")
}

model Deal {
  id          String         @id @default(cuid())
  tenantId    String
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id])
  title       String
  value       Decimal        @db.Decimal(15, 2)
  stage       String         @default("LEAD") // LEAD, PROPOSAL, NEGOTIATION, CLOSED_WON, CLOSED_LOST
  probability Int            @default(0)
  closeDate   DateTime?
  ownerId     String?
  notes       String?
  activities  DealActivity[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId, stage])
  @@map("deals")
}

model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  type      String   // CALL, EMAIL, MEETING, NOTE
  text      String
  createdAt DateTime @default(now())

  @@map("deal_activities")
}

// =============================================================================
// FRANCHISE HR
// =============================================================================

model FranchisePolicy {
  id          String   @id @default(cuid())
  tenantId    String   // franchisor tenant
  name        String
  description String   @db.Text
  scope       String   @default("ALL")
  mandatory   Boolean  @default(false)
  content     Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("franchise_policies")
}

model FranchiseBranch {
  id              String   @id @default(cuid())
  franchisorId    String   // parent tenant
  franchiseeTenantId String? // child tenant
  name            String
  city            String?
  managerName     String?
  managerEmail    String?
  compliance      Int      @default(0)
  status          String   @default("GOOD")
  openIssues      Int      @default(0)
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([franchisorId])
  @@map("franchise_branches")
}

// =============================================================================
// MEHNAT BIRJASI (LABOR EXCHANGE)
// =============================================================================

model LaborPost {
  id          String   @id @default(cuid())
  tenantId    String   // posting company
  title       String
  skills      String[]
  duration    String
  rate        Decimal  @db.Decimal(15, 2)
  rateType    String   @default("kunlik") // kunlik, oylik, loyiha
  workersNeeded Int    @default(1)
  urgency     String   @default("NORMAL") // URGENT, NORMAL
  location    String?
  description String?
  status      String   @default("ACTIVE") // ACTIVE, FILLED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications LaborApplication[]

  @@index([tenantId])
  @@index([status])
  @@map("labor_posts")
}

model LaborApplication {
  id          String     @id @default(cuid())
  postId      String
  post        LaborPost  @relation(fields: [postId], references: [id])
  fromTenantId String   // applying company
  employeeId  String?   // the worker being offered
  proposedRate Decimal? @db.Decimal(15, 2)
  message     String?
  status      String    @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime  @default(now())

  @@index([postId])
  @@map("labor_applications")
}

model LaborContract {
  id            String   @id @default(cuid())
  postId        String?
  hiringTenantId String
  offeringTenantId String
  employeeId    String
  startDate     DateTime
  endDate       DateTime?
  rate          Decimal  @db.Decimal(15, 2)
  rateType      String
  status        String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  rating        Int?
  review        String?
  createdAt     DateTime @default(now())

  @@index([hiringTenantId])
  @@index([offeringTenantId])
  @@map("labor_contracts")
}
